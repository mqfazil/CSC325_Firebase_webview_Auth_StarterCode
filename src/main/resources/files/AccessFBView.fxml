<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="620.0" prefWidth="920.0"
      xmlns="http://javafx.com/javafx/20.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.csc325_firebase_webview_auth.view.AccessFBView"
      stylesheets="@style.css">

    <MenuBar styleClass="menu-bar">
        <menus>
            <Menu text="File">
                <items>
                    <MenuItem text="Register / Sign In" onAction="#openLoginView" />
                    <MenuItem text="Sign Out" onAction="#handleSignOut" />
                    <SeparatorMenuItem />
                    <MenuItem text="Close" onAction="#handleClose" />
                </items>
            </Menu>
            <Menu text="Data">
                <items>
                    <MenuItem text="Add Record" onAction="#addRecord" />
                    <MenuItem text="Read Records" onAction="#readRecord" />
                    <MenuItem text="Clear Table" onAction="#clearTable" />
                </items>
            </Menu>
            <Menu text="View">
                <items>
                    <MenuItem text="Web View" onAction="#switchToSecondary" />
                </items>
            </Menu>
            <Menu text="Help">
                <items>
                    <MenuItem text="About" onAction="#showAbout" />
                </items>
            </Menu>
        </menus>
    </MenuBar>

    <HBox VBox.vgrow="ALWAYS">

        <!-- LEFT: Profile Panel -->
        <VBox styleClass="left-panel" prefWidth="195.0" spacing="12.0" alignment="TOP_CENTER">
            <children>
                <Label text="Profile" style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:white;" />
                <AnchorPane prefHeight="150.0" prefWidth="150.0"
                            style="-fx-background-color:white; -fx-background-radius:75; -fx-border-radius:75; -fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.3),10,0,0,3);">
                    <ImageView fx:id="profileImageView" fitHeight="150.0" fitWidth="150.0"
                               preserveRatio="true" pickOnBounds="true"
                               AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
                               AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0" />
                </AnchorPane>
                <Button text="Upload Photo" styleClass="form-button" prefWidth="160.0"
                        onAction="#uploadProfilePicture" />
                <Label fx:id="loggedInLabel" text="Not signed in"
                       style="-fx-font-size:11px; -fx-text-fill:white;" wrapText="true" />
            </children>
            <padding><Insets bottom="20.0" left="15.0" right="15.0" top="20.0" /></padding>
        </VBox>

        <!-- CENTER: TableView -->
        <VBox VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" spacing="8.0"
              style="-fx-background-color:#f9f9f9;">
            <children>
                <Label text="Student Records"
                       style="-fx-font-size:16px; -fx-font-weight:bold; -fx-padding:5 0 0 5;" />
                <TableView fx:id="personTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="nameColumn" prefWidth="220.0" text="Name" />
                        <TableColumn fx:id="majorColumn" prefWidth="220.0" text="Major" />
                        <TableColumn fx:id="ageColumn" prefWidth="100.0" text="Age" />
                    </columns>
                    <placeholder>
                        <Label text="No records yet. Fill the form and click Add Record." />
                    </placeholder>
                </TableView>
                <Label fx:id="statusLabel" text="Ready" styleClass="status-bar" />
            </children>
            <padding><Insets bottom="10.0" left="10.0" right="10.0" top="5.0" /></padding>
        </VBox>

        <!-- RIGHT: Form Panel -->
        <VBox prefWidth="240.0" spacing="10.0"
              style="-fx-background-color:#efefef; -fx-border-color:#ddd; -fx-border-width:0 0 0 1;">
            <children>
                <Label text="Add Student"
                       style="-fx-font-size:14px; -fx-font-weight:bold;" />
                <TextField fx:id="nameField" promptText="Name" />
                <TextField fx:id="majorField" promptText="Major" />
                <TextField fx:id="ageField" promptText="Age" />
                <Button fx:id="writeButton" text="Add Record" styleClass="form-button"
                        prefWidth="210.0" onAction="#addRecord" />
                <Button fx:id="readButton" text="Read Records" styleClass="form-button"
                        prefWidth="210.0" onAction="#readRecord" />
                <Button text="Clear Form" prefWidth="210.0" onAction="#clearForm"
                        style="-fx-background-color:#ccc; -fx-background-radius:15; -fx-pref-height:40;" />
                <Button text="Web View" prefWidth="210.0" onAction="#switchToSecondary"
                        style="-fx-background-color:#5b7fa6; -fx-text-fill:white; -fx-background-radius:15; -fx-pref-height:40;" />
            </children>
            <padding><Insets bottom="20.0" left="15.0" right="15.0" top="20.0" /></padding>
        </VBox>

    </HBox>
</VBox>
