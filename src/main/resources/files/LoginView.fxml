<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="500.0" prefWidth="900.0"
           xmlns="http://javafx.com/javafx/20.0.1"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.csc325_firebase_webview_auth.view.LoginController"
           styleClass="auth-root">
    <children>
        <HBox>
            <!-- Left branding panel -->
            <VBox styleClass="auth-left-panel" prefWidth="420.0" alignment="CENTER" spacing="16.0">
                <children>
                    <Label text="📚" styleClass="auth-brand-icon" />
                    <Label text="Student Registry" styleClass="auth-brand-title" />
                    <Label text="Firebase-Powered&#10;Management System" styleClass="auth-brand-subtitle" wrapText="true" />
                </children>
                <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>
            </VBox>

            <!-- Right form panel -->
            <VBox styleClass="auth-right-panel" prefWidth="480.0" alignment="CENTER" spacing="0.0">
                <children>
                    <!-- Tab Switcher -->
                    <HBox styleClass="auth-tabs" prefWidth="480.0">
                        <children>
                            <Button fx:id="loginTabBtn" text="Sign In" styleClass="auth-tab-active"
                                    prefWidth="240.0" onAction="#showLoginTab" />
                            <Button fx:id="registerTabBtn" text="Register" styleClass="auth-tab"
                                    prefWidth="240.0" onAction="#showRegisterTab" />
                        </children>
                    </HBox>

                    <!-- LOGIN FORM -->
                    <VBox fx:id="loginPane" spacing="16.0" prefWidth="400.0">
                        <children>
                            <Label text="Welcome back" styleClass="auth-form-title" />
                            <Label text="Sign in to your account" styleClass="auth-form-subtitle" />

                            <VBox spacing="6.0">
                                <Label text="Email" styleClass="auth-field-label" />
                                <TextField fx:id="loginEmail" promptText="you@example.com" styleClass="auth-field" />
                            </VBox>
                            <VBox spacing="6.0">
                                <Label text="Password" styleClass="auth-field-label" />
                                <PasswordField fx:id="loginPassword" promptText="Password" styleClass="auth-field" />
                            </VBox>

                            <Label fx:id="loginMessage" text="" styleClass="auth-message" wrapText="true" />

                            <Button text="Sign In" styleClass="form-button" prefWidth="400.0"
                                    onAction="#handleLogin" />
                        </children>
                        <padding><Insets bottom="40.0" left="40.0" right="40.0" top="30.0" /></padding>
                    </VBox>

                    <!-- REGISTER FORM -->
                    <VBox fx:id="registerPane" spacing="14.0" prefWidth="400.0" visible="false" managed="false">
                        <children>
                            <Label text="Create account" styleClass="auth-form-title" />
                            <Label text="Fill in your details to register" styleClass="auth-form-subtitle" />

                            <HBox spacing="10.0">
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <Label text="First Name" styleClass="auth-field-label" />
                                    <TextField fx:id="regFirstName" promptText="First name" styleClass="auth-field" />
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <Label text="Last Name" styleClass="auth-field-label" />
                                    <TextField fx:id="regLastName" promptText="Last name" styleClass="auth-field" />
                                </VBox>
                            </HBox>

                            <VBox spacing="5.0">
                                <Label text="Email" styleClass="auth-field-label" />
                                <TextField fx:id="regEmail" promptText="you@example.com" styleClass="auth-field" />
                            </VBox>
                            <VBox spacing="5.0">
                                <Label text="Password" styleClass="auth-field-label" />
                                <PasswordField fx:id="regPassword" promptText="Min 6 characters" styleClass="auth-field" />
                            </VBox>
                            <VBox spacing="5.0">
                                <Label text="Phone (optional)" styleClass="auth-field-label" />
                                <TextField fx:id="regPhone" promptText="+1 234 567 8900" styleClass="auth-field" />
                            </VBox>

                            <Label fx:id="registerMessage" text="" styleClass="auth-message" wrapText="true" />

                            <Button text="Create Account" styleClass="form-button" prefWidth="400.0"
                                    onAction="#handleRegister" />
                        </children>
                        <padding><Insets bottom="30.0" left="40.0" right="40.0" top="20.0" /></padding>
                    </VBox>
                </children>
            </VBox>
        </HBox>
    </children>
</StackPane>
